<UserControl x:Class="WpfApp3.Pages.Components.ServiceUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WpfApp3.Pages.Components"
             mc:Ignorable="d" 
             d:DesignHeight="200" d:DesignWidth="750">
    <Border BorderThickness="2" BorderBrush="LightGray">
        <Grid Width="750">
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="41*"/>
            <ColumnDefinition Width="110*"/>
        </Grid.ColumnDefinitions>
        <Image Name="ServiceImg" Grid.Column="0" Grid.RowSpan="4" Margin="10" Source="{Binding GetImage}"></Image>
        <TextBlock x:Name="TitleTb" Grid.Column="1" Grid.Row="0" Text="{Binding Title}">
            
        </TextBlock>
        
        <StackPanel Grid.Column="1" Grid.Row="1" Orientation="Horizontal">
                <TextBlock x:Name="CostTb" Grid.Column="1" Grid.Row="1" Text="{Binding Cost}" 
                       TextDecorations="Strikethrough"
                Visibility="{Binding CostVisibl}">

                </TextBlock>

            <TextBlock x:Name="CostStrTb" Text="{Binding CostStr}">
            </TextBlock>
        </StackPanel>
        <TextBlock x:Name="DiscountTb" Grid.Column="1" Grid.Row="2" Text="{Binding DiscountTb}">
        </TextBlock>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Grid.Column="1" Grid.Row="3">
            <Button x:Name="EditBtn">Редактировать</Button>
            <Button x:Name="DeleteBtn">Удалить</Button>
        </StackPanel>
    </Grid>
    </Border>
</UserControl>
